---
//@ts-nocheck
const { kunstner, slug } = Astro.props;

import "../styles/global.css";
import { Image } from "astro:assets";
import luk from "../assets/luk.webp";
import instagram from "../assets/insta.webp";
import spotify from "../assets/spotify.webp";
---

<dialog id={`artistPopover-${slug}`} class="background">
  <div class="stickyBox">
    <button
      onclick="this.closest('dialog').close()"
      id="close_btn"
      class="lukBtn"><Image src={luk} alt="Luk knap" /></button
    >
  </div>

  <article>
    <div class="container">
      <img
        src={kunstner.kunstner_billede}
        alt={kunstner.kunstner_navn}
        class="kunstnerImg"
      />
      <h1 class="kunstnerNavn">{kunstner.kunstner_navn}</h1>
    </div>

    <div class="enkeltkunstnertekst">
      <p>{kunstner.om_kunstner}</p>
      <br />
      <p>De er her {kunstner.dato}</p>
      <p>Du kan hører dem {kunstner.tid}</p>

      <div class="knapper">
        <a href={kunstner.instagram_link}
          ><Image
            src={instagram}
            alt=`link ${kunstner.kunstner_navn}s instagram`
          /></a
        >
        <a href={kunstner.spotify_link}
          ><Image
            src={spotify}
            alt=`link ${kunstner.kunstner_navn}s spotify`
          /></a
        >
      </div>
    </div>
  </article>
</dialog>

<style>
  dialog {
    display: grid;
    grid-template-columns: 1fr;
    border: none;
    width: 50%;
    max-height: 70vh;
    color: #ffff;
    margin: auto;
    overflow-y: auto;
  }

  .knapper {
    display: grid;
    grid-template-columns: 1fr 0.7fr;
    padding: 1rem;
    padding-top: 3rem;
    gap: 1rem;
  }

  .enkeltkunstnertekst {
    padding: 1rem;
    width: 75%;
    justify-self: center;
  }

  .kunstnerImg {
    object-fit: cover;
    aspect-ratio: 16/9;
    width: 100%;
    display: block;
  }

  .container {
    position: relative;
    text-align: center;
    width: 100%;
  }

  .kunstnerNavn {
    position: absolute;
    top: 50%;
    left: 50%;
    bottom: 50%;
    transform: translateX(-50%);
    margin: 0;
    z-index: 2;
    width: calc(100% - 2rem);
    font-size: 4vw;
  }

  .knapper a:hover {
    cursor: pointer;
    filter: saturate(130%);
  }

  @media screen and (max-width: 600px) {
    dialog {
      margin: auto;
      width: 80%;
      max-height: 80vh;
    }

    .enkeltkunstnertekst {
      width: 90%;
    }
  }
</style>
